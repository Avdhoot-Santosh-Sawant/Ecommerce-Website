body {
  background-color: white;
}

.back-arrow {
  display: inline-block;
  width: 20px;
  font-size: 30px;
  margin-left: 15px;
}

#empty-icon img {
  width: 60%;
  margin-top: 50px;
  margin-left: 20%;
  border: 5px solid green;
}
/* width */
::-webkit-scrollbar {
  width: 5px;
}

/* Track */
::-webkit-scrollbar-track {
  background: #f1f1f1;
}

/* Handle */
::-webkit-scrollbar-thumb {
  background: #888;
}

/* Handle on hover */
::-webkit-scrollbar-thumb:hover {
  background: #555;
}

.cart-div {
  width: 98%;
  padding: 5px;
  margin: auto;
  background-color: white;
  max-height: 350px;
  overflow-y: scroll;
  background-color: rgb(221, 235, 248);
}

.cart-con {
  width: 96%;
  margin: auto;
  background-color: rgb(221, 235, 248);
}

.cart-total-buy {
  text-align: end;
  margin-top: 10px;
  margin-bottom: 10px;
}

#total-price {
  font-size: 18px;
  font-weight: 600;
  padding: 5px;
}

#buy-btn {
  border: 1px solid green;
  color: white;
  font-weight: 600;
  padding: 2px 10px;
  border-radius: 5px;
  background-color: green;
}
@media screen and (min-width: 500px) {
  .cart-div {
    width: 90%;
    padding: 5px;
    margin: auto;
  }

  .cart-con {
    width: 96%;
    margin: auto;
  }

  #empty-icon {
    width: 100%;
    margin-top: 10px;
  }
}

.outer-sign-up-con{

    width:95%;
    margin:auto;
    padding: 7px 15px;
    border: 1px solid rgb(43, 134, 219);
    border-radius: 10px;
    box-shadow:0px 5px 6px black;
    background-color: white;
    
    }

    .text-header{
        
        font-weight: 600;
    }
    .lable{
        font-size: 16px;     
        margin-bottom: 5px;
        font-weight: 700;
        
    }
    
    #sign-up-email,
    #sign-up-password,
    #sign-up-name,
    #sign-up-number{
       border-bottom: 2px;
        width: 100%;
        font-size: 16px;
        border: 1px solid rgb(160, 151, 151);
        border-radius: 5px;
        padding: 3px 10px;
       
    }
    .text-header{
        text-align: center;
    }
    
    
    #sign-up{
        border:1px solid blue !important;
        background-color: blue !important;
        display:inline-block;
        width:80%;padding: 5px;
        border-radius: 10px;
        color: white;
        margin-left: 10%;
        font-weight: 700;
        margin-top: 20px;
    }
    
    #sign-in-btn{
        display: inline-block;
        color: blue;
        font-weight: 600;
    }
    
   .error-massage{
    display: block;
    color:red;
    border-bottom: 10px;
   }

   .field{
    margin-bottom: 10px;
   }
    
    @media screen and (min-width:500px) {
        
         .outer-sign-up-con{
            width: 500px;
         }
    
    
    
    }

.outer-sign-in-con{

    width:95%;
    margin:auto;
    padding: 15px;
    border: 1px solid rgb(43, 134, 219);
    border-radius: 10px;
    box-shadow:0px 5px 6px black;
    background-color: white;
    
    }
    .text-header{
        margin-bottom: 20px;
        font-weight: 700;
    }
    .lable{
        font-size: 20px; 
        margin-bottom: 5px;
        font-weight: 700;
        
    }
    
    #sign-in-email,
    #sign-in-password{
        margin-bottom: 2px;
        width:100%;
        border: 1px solid rgb(160, 151, 151);
        border-radius: 5px;
        padding: 5px;
    }
    .text-header{
        text-align: center;
    }
    
    
    #sign-in{
        border:1px solid blue !important;
        background-color: blue !important;
        display:inline-block;
        width:80%;padding: 5px;
        border-radius: 10px;
        color: white;
        margin-left: 10%;
        font-weight: 700;
        margin-top: 20px;
    }
    
    #sign-up-btn{
        display: inline-block;
        color: blue;
        font-weight: 600;
    }
    
    
    @media screen and (min-width:500px) {
        
         .outer-sign-in-con{
            width: 500px;
         }
    
    
    
    }